<Window x:Class="Hourglass.Windows.ErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:Hourglass.Properties"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        TextOptions.TextFormattingMode="Display"
        RenderOptions.ClearTypeHint="Enabled"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen"
        FocusManager.FocusedElement="{Binding ElementName=CloseButton, Mode=OneWay}">
    <Window.Resources>
        <FontFamily x:Key="LightFontFamily">Segoe UI Light, Segoe UI</FontFamily>
        <FontFamily x:Key="PrimaryFontFamily">Segoe UI</FontFamily>
        <FontFamily x:Key="MonospaceFontFamily">Consolas, Courier New, Courier</FontFamily>
        <Style x:Key="DetailsButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#0066CC"/>
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}"/>
            <Setter Property="Margin" Value="15 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <TextBlock>
                            <ContentPresenter RecognizesAccessKey="True"/>
                        </TextBlock>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Foreground" Value="#FF0000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#F9F9F9">
        <StackPanel>
            <TextBlock x:Name="TitleTextBlock"
                       TextOptions.TextFormattingMode="Ideal"
                       Background="#C75050"
                       FontFamily="{StaticResource LightFontFamily}"
                       FontSize="20"
                       Foreground="#F5F5F5"
                       Padding="15 20 80 20"/>
            <Border x:Name="MessageBorder" BorderBrush="#DDDDDD" BorderThickness="0 0 0 1" Visibility="Collapsed">
                <TextBox x:Name="MessageTextBox"
                         Background="{x:Null}"
                         BorderThickness="0"
                         Margin="0"
                         Padding="13"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"/>
            </Border>
            <Border x:Name="DetailsBorder" BorderBrush="#DDDDDD" BorderThickness="0 0 0 1" Visibility="Collapsed">
                <TextBox x:Name="DetailsTextBox"
                         Background="{x:Null}"
                         BorderThickness="0"
                         Margin="0"
                         Padding="13"
                         FontFamily="{StaticResource MonospaceFontFamily}"
                         FontSize="12"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"/>
            </Border>
            <Grid Background="#F9F9F9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Margin="10 0 5 0" VerticalAlignment="Center">
                        <Hyperlink Click="ReportBugButtonClick">
                            <Run Text="{x:Static properties:Resources.ErrorDialogReportBugButtonContent}"/>
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Margin="5 0 10 0" VerticalAlignment="Center">
                        <Hyperlink x:Name="CopyToClipboardButton" Click="CopyToClipboardButtonClick">
                            <Run Text="{x:Static properties:Resources.ErrorDialogCopyToClipboardButtonContent}"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
                <Button x:Name="ShowDetailsButton"
                        Grid.Column="1"
                        Click="ShowDetailsButtonClick"
                        HorizontalAlignment="Center"
                        IsEnabled="True"
                        Style="{StaticResource DetailsButtonStyle}"
                        VerticalAlignment="Center"/>
                <Button x:Name="CloseButton"
                        Grid.Column="2"
                        Margin="10"
                        Padding="35 4"
                        IsDefault="True"
                        IsCancel="True"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
