<Window x:Class="Hourglass.Windows.UsageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Hourglass"
        xmlns:properties="clr-namespace:Hourglass.Properties"
        xmlns:windows="clr-namespace:Hourglass.Windows"
        Loaded="WindowLoaded"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        TextOptions.TextFormattingMode="Display"
        RenderOptions.ClearTypeHint="Enabled"
        SnapsToDevicePixels="True"
        Title="{x:Static properties:Resources.UsageDialogTitle}"
        Closed="UsageDialogClosed"
        WindowStartupLocation="CenterScreen"
        FocusManager.FocusedElement="{Binding ElementName=CloseButton, Mode=OneWay}">
    <Window.Resources>
        <FontFamily x:Key="MonospaceFontFamily">Consolas, Courier New, Courier</FontFamily>
        <FontFamily x:Key="LightFontFamily">Segoe UI Light, Segoe UI</FontFamily>
        <Style x:Key="HyperlinkStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="15 0 0 0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="MessageTextBlock"
                   Focusable="False"
                   TextOptions.TextFormattingMode="Ideal"
                   Background="Gray"
                   FontFamily="{StaticResource LightFontFamily}"
                   FontSize="20"
                   Foreground="#F5F5F5"
                   Padding="15 20 80 20"/>
        <TextBox x:Name="UsageTextBox"
                 Grid.Row="1"
                 BorderThickness="0"
                 Margin="0"
                 Padding="13 0 13 0"
                 FontFamily="{StaticResource MonospaceFontFamily}"
                 IsReadOnly="True"
                 IsReadOnlyCaretVisible="True"
                 IsInactiveSelectionHighlightEnabled="True"
                 SelectionBrush="{x:Static SystemColors.HighlightBrush}"
                 SelectionTextBrush="{x:Static SystemColors.HighlightTextBrush}"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 Text="{Binding Source={x:Static local:CommandLineArguments.Usage}, Mode=OneTime}">
        </TextBox>
        <Border x:Name="SearchBar"
                Grid.Row="2"
                Visibility="Collapsed"
                Background="#F0F0F0"
                BorderBrush="#DDDDDD"
                BorderThickness="0 1 0 0"
                Padding="8 5 8 5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchTextBox"
                         BorderThickness="1"
                         Padding="4 2"
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="MatchCountTextBlock"
                           Grid.Column="1"
                           Visibility="Collapsed"
                           VerticalAlignment="Center"
                           Margin="5 0 0 0"
                           FontSize="11"/>
            </Grid>
        </Border>
        <Border Grid.Row="3" Background="#F9F9F9" BorderBrush="#DDDDDD" BorderThickness="0 1 0 0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource HyperlinkStyle}">
                    <Hyperlink Click="AboutHourglassHyperlinkClick">
                        <Run Text="{x:Static properties:Resources.UsageDialogAboutHourglassHyperlinkText}"/>
                    </Hyperlink>
                </TextBlock>
                <TextBlock Grid.Column="1" Style="{StaticResource HyperlinkStyle}">
                    <Hyperlink NavigateUri="{x:Static local:Urls.FAQ}" RequestNavigate="HyperlinkRequestNavigate">
                        <Run Text="{x:Static properties:Resources.UsageDialogFAQHyperlinkText}"/>
                    </Hyperlink>
                </TextBlock>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Style="{StaticResource HyperlinkStyle}" Margin="0">
                        <Hyperlink NavigateUri="{x:Static local:Urls.Usage}" RequestNavigate="HyperlinkRequestNavigate">
                            <Run Text="{x:Static properties:Resources.UsageDialogCommandLineUsageOnWebHyperlinkText}"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Name="CloseButton"
                            Click="CloseButtonClick"
                            Content="{x:Static properties:Resources.UsageDialogCloseButtonContent}"
                            IsDefault="True"
                            IsCancel="True"
                            Margin="0 10 10 10"
                            Width="100"
                            Height="25"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
